# ManoProtect Backend - Environment Variables
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=manoprotect

# CORS (comma separated origins)
CORS_ORIGINS=https://manoprotect.com,https://www.manoprotect.com

# Emergent LLM Key (for AI features)
EMERGENT_LLM_KEY=your_emergent_llm_key

# Stripe (Payments)
STRIPE_API_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# JWT Secret (generate a random 32+ char string)
JWT_SECRET=your_super_secret_jwt_key_here

# Superadmin
SUPERADMIN_EMAIL=admin@yourdomain.com

# Firebase Cloud Messaging (FCM) - VAPID
VAPID_CLAIMS_EMAIL=your_email@domain.com

# Infobip SMS - https://portal.infobip.com
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_SENDER=ManoProtect

# Nordigen (Banking API - Optional)
NORDIGEN_SECRET_ID=your_nordigen_secret_id
NORDIGEN_SECRET_KEY=your_nordigen_secret_key
