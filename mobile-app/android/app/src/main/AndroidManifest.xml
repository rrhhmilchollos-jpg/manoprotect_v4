<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ========================================== -->
    <!-- PERMISOS MÍNIMOS PARA GOOGLE PLAY -->
    <!-- ========================================== -->
    
    <!-- Internet para comunicación con servidor -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- NOTIFICACIONES: Para push notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- UBICACIÓN: Solo cuando se activa SOS (no en segundo plano por defecto) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- VIBRACIÓN: Para alertas -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- FOREGROUND SERVICE: Solo durante SOS activo -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    
    <!-- WAKE LOCK: Para mantener activo durante alerta -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- FULL SCREEN INTENT: Para mostrar alerta importante -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    
    <!-- BIOMETRÍA: Para autenticación segura -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    
    <!-- CÁMARA: Para escanear códigos QR (opcional) -->
    <uses-permission android:name="android.permission.CAMERA" />
    
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">
        
        <!-- ACTIVIDAD PRINCIPAL -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mano" />
                <data android:scheme="manoprotect" />
            </intent-filter>
        </activity>
        
        <!-- PANTALLA DE AVISO SOS -->
        <activity
            android:name="com.manoprotect.sos.SOSLockScreenActivity"
            android:label="Aviso Personal"
            android:theme="@style/AppTheme.Fullscreen"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:exported="false">
        </activity>
        
        <!-- SERVICIO DE AVISO SOS -->
        <service
            android:name="com.manoprotect.sos.SOSCriticalAlertService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location">
        </service>
        
        <!-- FIREBASE CLOUD MESSAGING -->
        <service
            android:name="com.manoprotect.sos.SOSFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        
        <!-- Configuración FCM -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="personal_alerts" />
        
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification" />
        
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_red" />
        
        <!-- Google Play Services -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

    </application>

</manifest>
