{
  "name": "Mano",
  "displayName": "Mano",
  "version": "1.0.0",
  "description": "Protección contra fraudes y estafas digitales",
  "author": "Mano Security",
  "license": "PROPRIETARY",
  "ios": {
    "bundleIdentifier": "com.Manoprotect.Mano",
    "buildNumber": "1",
    "infoPlist": {
      "NSCameraUsageDescription": "Mano necesita acceso a la cámara para escanear códigos QR sospechosos",
      "NSContactsUsageDescription": "Mano necesita acceso a tus contactos para configurar contactos de emergencia",
      "NSFaceIDUsageDescription": "Usa Face ID para acceder de forma segura a Mano",
      "NSLocationWhenInUseUsageDescription": "Mano usa tu ubicación para alertas de emergencia SOS",
      "UIBackgroundModes": ["fetch", "remote-notification"]
    },
    "capabilities": {
      "push": true,
      "backgroundFetch": true
    }
  },
  "android": {
    "package": "com.Manoprotect.Mano",
    "versionCode": 1,
    "permissions": [
      "android.permission.CAMERA",
      "android.permission.READ_CONTACTS",
      "android.permission.USE_BIOMETRIC",
      "android.permission.USE_FINGERPRINT",
      "android.permission.ACCESS_FINE_LOCATION",
      "android.permission.VIBRATE",
      "android.permission.RECEIVE_BOOT_COMPLETED",
      "android.permission.INTERNET",
      "android.permission.ACCESS_NETWORK_STATE"
    ],
    "adaptiveIcon": {
      "foreground": "./assets/adaptive-icon-foreground.png",
      "background": "#1a1a2e"
    },
    "googleServicesFile": "./android/app/google-services.json"
  },
  "splash": {
    "image": "./assets/splash.png",
    "backgroundColor": "#1a1a2e",
    "resizeMode": "contain"
  },
  "icon": "./assets/icon.png",
  "primaryColor": "#6366f1",
  "scheme": "mano"
}
