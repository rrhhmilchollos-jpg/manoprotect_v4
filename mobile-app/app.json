{
  "expo": {
    "name": "Mano",
    "slug": "mano",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.Manoprotect.Mano",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Mano necesita acceso a la cámara para escanear códigos QR sospechosos",
        "NSContactsUsageDescription": "Mano necesita acceso a tus contactos para configurar contactos de emergencia",
        "NSFaceIDUsageDescription": "Usa Face ID para acceder de forma segura a Mano",
        "NSLocationWhenInUseUsageDescription": "Mano usa tu ubicación para alertas de emergencia SOS",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "config": {
        "googleServicesFile": "./GoogleService-Info.plist"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.Manoprotect.Mano",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Mano necesita acceso a la cámara para escanear códigos QR"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Mano necesita acceso a tus contactos"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mano usa tu ubicación para alertas SOS"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "owner": "manoprotect"
  }
}
