{
  "name": "manobank-app",
  "version": "1.0.0",
  "description": "ManoBank S.A. - Banca Digital Segura",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Web app loaded from remote URL'",
    "cap:init": "npx cap init ManoBank com.manobank.app",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build": "npx cap sync && cd android && ./gradlew assembleDebug",
    "cap:build:release": "npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "keywords": ["banking", "fintech", "manobank"],
  "author": "ManoBank S.A.",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/camera": "^5.0.0",
    "@capacitor/geolocation": "^5.0.0",
    "@capacitor/push-notifications": "^5.0.0"
  }
}
