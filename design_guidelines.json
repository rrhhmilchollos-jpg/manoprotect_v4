      "social_proof": [
        {
          "url": "https://images.pexels.com/photos/7534791/pexels-photo-7534791.jpeg",
          "alt": "Trustworthy Professional",
          "usage": "Testimonial avatar or support agent"
        }
      ]
    },
    "icons": {
      "library": "lucide-react",
      "preferred": ["ShieldCheck", "Lock", "Smartphone", "CreditCard", "Users", "CheckCircle2", "AlertTriangle", "Clock"]
    }
  },
  "layouts": {
    "hero_section": {
      "structure": "Split Layout (Text Left, Image Right) or Centered with Background Blur",
      "elements": [
        "H1: Bold, High Contrast (Manrope)",
        "Subtext: Clear value prop (Inter)",
        "Primary CTA: Solid Color, Rounded-Full",
        "Secondary CTA: Outline or Ghost",
        "Trust Badges: 'Verified by...', 'Secure' icons below CTA"
      ]
    },
    "bento_grid": {
      "structure": "Grid with varied spans (col-span-1, col-span-2)",
      "usage": "Features Section",
      "rules": [
        "Use 'Tetris' logic: Mix tall cards, wide cards, and square cards.",
        "Don't make every card the same size.",
        "Use light background colors (bg-slate-50) for cards with subtle borders."
      ]
    },
    "testimonials": {
      "structure": "Carousel (Shadcn) or Masonry Grid",
      "style": "Card-based, shadow-sm, rounded-xl. Include star ratings."
    }
  },
  "components": {
    "required_custom": [
      {
        "name": "FloatingWhatsApp",
        "position": "Fixed Bottom Right",
        "style": "Green-500, Rounded-Full, Shadow-2xl, Pulse Effect on Hover",
        "content": "Icon + '¿Ayuda?' text"
      },
      {
        "name": "UrgencyBanner",
        "position": "Top of page (Sticky)",
        "style": "bg-orange-600 text-white text-sm font-medium py-2 text-center",
        "content": "Countdown timer or 'Limited Time Offer' text"
      },
      {
        "name": "ServiceSwitcher",
        "position": "Navbar or Hero Top",
        "style": "Toggle or Tabs to switch between ManoProtect and ManoBank views easily"
      }
    ],
    "shadcn_overrides": {
      "button": "rounded-full font-semibold shadow-md hover:shadow-lg transition-all",
      "card": "rounded-2xl border-slate-100 shadow-sm hover:shadow-md transition-all",
      "input": "bg-slate-50 border-slate-200 focus:ring-2 focus:ring-indigo-500"
    }
  },
  "instructions_to_main_agent": [
    "Implement the 'FloatingWhatsApp' component immediately and add it to the root layout.",
    "Refactor the LandingPage.js to use the 'Bento Grid' layout for features.",
    "Ensure distinct visual identities: ManoProtect = Indigo, ManoBank = Blue.",
    "Add the 'UrgencyBanner' to the top of both landing pages.",
    "Use the provided image URLs for the respective sections. Do not use placeholders.",
    "Optimize for Mobile: Stack grids to 1 column, ensure touch targets are 44px+.",
    "Add 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": [
    "Avoid generic centered layouts. Use asymmetry.",
    "Use noise textures to avoid 'AI slop' flatness.",
    "Ensure text contrast ratios meet WCAG AA.",
    "Micro-animations on hover are mandatory."
  ]
}