{
  "identity": {
    "name": "E1",
    "role": "Anti-AI Designer",
    "principles": [
      "Fusion over Imitation",
      "Emotion First",
      "Content is King",
      "Zoom In",
      "Negative Space",
      "Contrast"
    ]
  },
  "project_context": {
    "app_name": "ManoProtect & ManoBank",
    "target_audience": "Spanish families (30-60 years old) concerned about digital security",
    "core_theme": "Trust, Security, Family, Professionalism",
    "platform": "Web (React + Tailwind + Shadcn)",
    "mode": "Light Mode (Primary) with High-Contrast Elements"
  },
  "design_system": {
    "typography": {
      "headings": {
        "font_family": "Manrope, sans-serif",
        "weights": ["600", "700", "800"],
        "usage": "Headings, Hero Titles, Feature Names",
        "letter_spacing": "tracking-tight"
      },
      "body": {
        "font_family": "Inter, sans-serif",
        "weights": ["400", "500"],
        "usage": "Paragraphs, UI Elements, Labels",
        "letter_spacing": "tracking-normal"
      },
      "accent": {
        "font_family": "Space Grotesk, monospace",
        "usage": "Numbers, Data, Urgency Counters (Use sparingly)"
      }
    },
    "colors": {
      "palettes": {
        "mano_protect": {
          "primary": "#4F46E5",
          "secondary": "#818CF8",
          "surface": "#EEF2FF",
          "text_contrast": "#312E81"
        },
        "mano_bank": {
          "primary": "#2563EB",
          "secondary": "#60A5FA",
          "surface": "#EFF6FF",
          "text_contrast": "#1E3A8A"
        },
        "shared": {
          "neutral_bg": "#FFFFFF",
          "neutral_text": "#0F172A",
          "neutral_muted": "#64748B",
          "urgency": "#EA580C",
          "success": "#10B981",
          "border": "#E2E8F0"
        }
      },
      "rules": [
        "Never use pure black (#000000). Use #0F172A or #020617.",
        "ManoProtect pages must lean into Indigo/Purple hues.",
        "ManoBank pages must lean into Blue/Sky hues.",
        "CTAs must be high contrast (Primary Color or Urgency Orange)."
      ]
    },
    "spacing": {
      "scale": "Tailwind Default",
      "rules": [
        "Use generous padding (py-20, py-24) for section separation.",
        "Grid gaps should be gap-8 or gap-12 for breathing room.",
        "Mobile padding: px-6 minimum."
      ]
    },
    "visual_enhancers": {
      "glassmorphism": "backdrop-blur-xl bg-white/70 border border-white/20 shadow-sm",
      "gradients": {
        "protect_hero": "bg-gradient-to-br from-indigo-50 to-white",
        "bank_hero": "bg-gradient-to-br from-blue-50 to-white",
        "glow": "shadow-[0_0_40px_-10px_rgba(79,70,229,0.3)]"
      },
      "textures": "Use subtle noise overlays on solid backgrounds to prevent 'flatness'.",
      "shadows": "shadow-lg for cards, shadow-xl for floating elements."
    }
  },
  "assets": {
    "images": {
      "hero_protect": {
        "url": "https://images.pexels.com/photos/5691823/pexels-photo-5691823.jpeg",
