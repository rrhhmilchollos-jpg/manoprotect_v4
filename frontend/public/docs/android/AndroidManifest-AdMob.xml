<!-- 
  ManoProtect - AndroidManifest.xml Modificaciones para AdMob
  
  INSTRUCCIONES:
  1. Abre el proyecto generado por PWABuilder en Android Studio
  2. Edita app/src/main/AndroidManifest.xml
  3. Añade/modifica las secciones marcadas con "AÑADIR"
-->

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.manoprotect.www.twa">

    <!-- Permisos necesarios para AdMob -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">

        <!-- ============================================ -->
        <!-- AÑADIR: AdMob App ID (REQUERIDO)            -->
        <!-- ============================================ -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-7713974112203810~9265947358"/>

        <!-- ============================================ -->
        <!-- AÑADIR: Splash Activity con Anuncio         -->
        <!-- Esta será la nueva actividad de inicio      -->
        <!-- ============================================ -->
        <activity
            android:name=".SplashAdActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ============================================ -->
        <!-- MODIFICAR: TWA LauncherActivity             -->
        <!-- Quitar intent-filter LAUNCHER               -->
        <!-- ============================================ -->
        <activity
            android:name="com.manoprotect.www.twa.LauncherActivity"
            android:exported="true"
            android:alwaysRetainTaskState="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:launchMode="singleTask">
            <!-- Ya NO es LAUNCHER, se lanza desde SplashAdActivity -->
            
            <!-- Intent filters para deep links (mantener) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="manoprotect.com"/>
                <data android:scheme="https" android:host="www.manoprotect.com"/>
            </intent-filter>
        </activity>

        <!-- Proveedor de Custom Tabs (mantener existente) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths" />
        </provider>

        <!-- Digital Asset Links verificación (mantener existente) -->
        <meta-data
            android:name="asset_statements"
            android:resource="@string/asset_statements" />

    </application>

</manifest>
