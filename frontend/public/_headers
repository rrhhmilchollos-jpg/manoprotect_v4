# ManoProtect Cache Headers for Production
# These headers will be applied by hosting providers like Vercel, Netlify, Cloudflare Pages

# Static Assets - Long cache (1 year)
/static/*
  Cache-Control: public, max-age=31536000, immutable

# JavaScript and CSS bundles
/*.js
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/*.css
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Fonts - Very long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Images - Long cache with revalidation
/*.png
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.jpg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.jpeg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.webp
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.svg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.ico
  Cache-Control: public, max-age=2592000

# Icons folder
/icons/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Manifest and Service Worker
/manifest.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# HTML pages - short cache, always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# API routes - no cache
/api/*
  Cache-Control: no-store, no-cache, must-revalidate

# Security headers for all routes - Enhanced for PageSpeed Security audit
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=()
  Content-Security-Policy: frame-ancestors 'self'; form-action 'self'; base-uri 'self'; default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com https://firebase.googleapis.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://firebase.googleapis.com https://firebaseinstallations.googleapis.com https://ipapi.co https://*.manoprotect.com https://*.emergent.host wss://*.emergent.host; frame-src 'self' https://js.stripe.com https://www.googletagmanager.com
  Cross-Origin-Opener-Policy: same-origin-allow-popups
