# ManoProtect Frontend - Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL
REACT_APP_BACKEND_URL=https://api.manoprotect.com

# WebSocket Config
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false

# Stripe (Publishable Key - safe to expose)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Brand Assets
REACT_APP_LOGO_URL=/manoprotect_logo.png
REACT_APP_ALERT_IMAGE_URL=/manoprotect_alert.png

# Firebase VAPID Key (for Push Notifications)
REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key
