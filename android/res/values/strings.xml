<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App Info -->
    <string name="app_name">ManoProtect</string>
    <string name="launcher_name">ManoProtect</string>
    
    <!-- TWA Configuration -->
    <string name="hostName">www.manoprotectt.com</string>
    <string name="launchUrl">/</string>
    <string name="defaultUrl">https://www.manoprotectt.com</string>
    
    <!-- Asset Statements for TWA verification -->
    <string name="assetStatements">
        [{
            \"relation\": [\"delegate_permission/common.handle_all_urls\"],
            \"target\": {
                \"namespace\": \"web\",
                \"site\": \"https://www.manoprotectt.com\"
            }
        }]
    </string>
    
    <!-- Notification Channels -->
    <string name="sos_channel_id">sos_emergency_critical</string>
    <string name="sos_channel_name">Alertas de Emergencia SOS</string>
    <string name="sos_channel_description">Notificaciones críticas de emergencia familiar. Estas alertas sonarán incluso en modo silencio.</string>
    
    <string name="general_channel_id">manoprotect_general</string>
    <string name="general_channel_name">Notificaciones Generales</string>
    <string name="general_channel_description">Actualizaciones y alertas de seguridad</string>
    
    <!-- Display Configuration -->
    <string name="displayMode">standalone</string>
    <string name="orientation">portrait</string>
    <string name="fallbackType">customtabs</string>
    
    <!-- Splash Configuration -->
    <integer name="splashScreenFadeOutDuration">300</integer>
    
    <!-- Version Info -->
    <string name="versionName">2.0.0</string>
    <integer name="versionCode">2</integer>
    
    <!-- Features -->
    <bool name="enableNotifications">true</bool>
    <bool name="enableLocationDelegation">true</bool>
    <bool name="enablePlayBilling">true</bool>
</resources>
